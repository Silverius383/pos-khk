# ================================================================
# SALIN FILE INI MENJADI .env.local  (jangan hapus file ini)
# ================================================================

# --- WAJIB DIISI ---

# Database PostgreSQL
# Pilihan 1 - Neon (gratis, online): daftar di neon.tech, copy connection string
# Pilihan 2 - Local PostgreSQL: install PostgreSQL di Windows
DATABASE_URL="postgresql://username:password@host:5432/nama_database?sslmode=require"

# Secret untuk enkripsi session cookie (isi bebas, min 32 karakter)
SESSION_SECRET="isi-dengan-string-acak-panjang-minimal-32-karakter-contoh-ini"

# --- OPSIONAL ---

# Password login (default: admin123)
ADMIN_PASSWORD="admin123"

// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String    @id @default(uuid())
  name         String
  category     String    @default("")
  buy_price    Int
  sell_price   Int
  stock        Int       @default(0)
  min_stock    Int       @default(5)
  expired_date DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  transaction_items TransactionItem[]

  @@map("products")
}

model Transaction {
  id             String   @id @default(uuid())
  total_amount   Int
  total_discount Int      @default(0)
  total_profit   Int
  payment_method String   @default("tunai")   // "tunai" | "transfer" | "qris"
  cash_received  Int?                          // uang diterima (tunai), null jika transfer/qris
  created_at     DateTime @default(now())

  items TransactionItem[]

  @@map("transactions")
}

model TransactionItem {
  id             String @id @default(uuid())
  transaction_id String
  product_id     String
  product_name   String
  quantity       Int
  sell_price     Int
  buy_price      Int
  discount_type  String  @default("none")
  discount_value Int     @default(0)
  discount_amount Int    @default(0)
  final_price    Int
  subtotal       Int
  profit         Int

  transaction Transaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [product_id], references: [id])

  @@map("transaction_items")
}

model Expense {
  id         String   @id @default(uuid())
  name       String
  amount     Int
  category   String   @default("Operasional")
  created_at DateTime @default(now())

  @@map("expenses")
}

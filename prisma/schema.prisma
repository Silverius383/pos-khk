// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String    @id @default(uuid())
  name         String
  category     String    @default("")
  buy_price    Int
  sell_price   Int
  stock        Int       @default(0)
  min_stock    Int       @default(5)
  expired_date DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  transaction_items TransactionItem[]

  @@map("products")
}

model Transaction {
  id             String   @id @default(uuid())
  total_amount   Int      // total setelah semua diskon
  total_discount Int      @default(0) // total nilai diskon (Rp)
  total_profit   Int      // profit setelah diskon
  created_at     DateTime @default(now())

  items TransactionItem[]

  @@map("transactions")
}

model TransactionItem {
  id             String @id @default(uuid())
  transaction_id String
  product_id     String
  product_name   String  // snapshot
  quantity       Int
  sell_price     Int     // snapshot harga normal
  buy_price      Int     // snapshot harga beli
  discount_type  String  @default("none")  // "none" | "percent" | "nominal"
  discount_value Int     @default(0)       // angka diskon (% atau Rp)
  discount_amount Int    @default(0)       // nilai diskon dalam Rp (hasil kalkulasi)
  final_price    Int     // harga jual setelah diskon per unit
  subtotal       Int     // final_price * quantity
  profit         Int     // (final_price - buy_price) * quantity

  transaction Transaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [product_id], references: [id])

  @@map("transaction_items")
}

model Expense {
  id         String   @id @default(uuid())
  name       String
  amount     Int
  category   String   @default("Operasional")
  created_at DateTime @default(now())

  @@map("expenses")
}
